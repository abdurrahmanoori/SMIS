@page "/counter"

<div class="counter-page">
    <SfCard>
        <CardHeader Title="Counter Demo" />
        <CardContent>
            <div class="counter-display">
                <SfChip>
                    <ChipItems>
                        <ChipItem Text="@($"Count: {currentCount}")" CssClass="e-primary"></ChipItem>
                    </ChipItems>
                </SfChip>
            </div>

            <div class="counter-controls">
                <SfButton CssClass="e-success" IconCss="e-icons e-plus" @onclick="IncrementCount">Increment</SfButton>
                <SfButton CssClass="e-danger" IconCss="e-icons e-minus" @onclick="DecrementCount">Decrement</SfButton>
                <SfButton CssClass="e-warning" IconCss="e-icons e-refresh" @onclick="ResetCount">Reset</SfButton>
            </div>

            <SfProgressBar Type="ProgressType.Linear" Value="@progressValue" Height="30" 
                          TrackThickness="24" ProgressThickness="24" ShowProgressValue="true">
            </SfProgressBar>
        </CardContent>
    </SfCard>
</div>

@code {
    private int currentCount = 0;
    private double progressValue => Math.Min((currentCount * 10), 100);

    private void IncrementCount()
    {
        currentCount++;
    }

    private void DecrementCount()
    {
        if (currentCount > 0)
            currentCount--;
    }

    private void ResetCount()
    {
        currentCount = 0;
    }
}

<style>
    .counter-page {
        max-width: 600px;
    }

    .counter-display {
        text-align: center;
        margin: 30px 0;
        font-size: 24px;
    }

    .counter-controls {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }
</style>
