@page "/product-form"
@page "/product-form/{ProductId:int}"
@using System.ComponentModel.DataAnnotations
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Inputs
@inject NavigationManager Navigation

<SfCard>
    <CardHeader Title="@(ProductId.HasValue ? "Edit Product" : "Add New Product")" />
    <CardContent>
        <EditForm Model="@product" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            
            <div class="form-row">
                <div class="form-group">
                    <label>Product Name <span class="required">*</span></label>
                    <SfTextBox @bind-Value="@product.Name" Placeholder="Enter product name"></SfTextBox>
                    <ValidationMessage For="@(() => product.Name)" />
                </div>

                <div class="form-group">
                    <label>SKU/Barcode</label>
                    <SfTextBox @bind-Value="@product.SKU" Placeholder="Enter SKU or barcode"></SfTextBox>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Category <span class="required">*</span></label>
                    <SfDropDownList TValue="string" TItem="string" @bind-Value="@product.Category" 
                                   DataSource="@categories" Placeholder="Select category">
                    </SfDropDownList>
                    <ValidationMessage For="@(() => product.Category)" />
                </div>

                <div class="form-group">
                    <label>Price <span class="required">*</span></label>
                    <SfNumericTextBox TValue="decimal?" @bind-Value="@product.Price" 
                                     Format="C2" Placeholder="0.00" Min="0">
                    </SfNumericTextBox>
                    <ValidationMessage For="@(() => product.Price)" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Stock Quantity <span class="required">*</span></label>
                    <SfNumericTextBox TValue="int?" @bind-Value="@product.Stock" 
                                     Placeholder="0" Min="0">
                    </SfNumericTextBox>
                    <ValidationMessage For="@(() => product.Stock)" />
                </div>

                <div class="form-group">
                    <label>Reorder Level</label>
                    <SfNumericTextBox TValue="int?" @bind-Value="@product.ReorderLevel" 
                                     Placeholder="Minimum stock level" Min="0">
                    </SfNumericTextBox>
                </div>
            </div>

            <div class="form-group full-width">
                <label>Product Image</label>
                <SfUploader ID="fileUpload" AllowedExtensions=".jpg,.jpeg,.png,.gif" MaxFileSize="2000000" AutoUpload="false">
                    <UploaderEvents ValueChange="@OnFileSelected"></UploaderEvents>
                </SfUploader>
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <div class="image-preview">
                        <img src="@product.ImageUrl" alt="Product preview" />
                    </div>
                }
            </div>

            <div class="form-group full-width">
                <label>Description</label>
                <SfTextBox @bind-Value="@product.Description" Multiline="true" RowCount="4"
                          Placeholder="Enter product description"></SfTextBox>
            </div>

            <div class="form-group full-width">
                <SfCheckBox @bind-Checked="@product.IsActive" Label="Active Product"></SfCheckBox>
            </div>

            <div class="form-actions">
                <SfButton Type="ButtonType.Submit" CssClass="e-primary" IconCss="e-icons e-save">
                    @(ProductId.HasValue ? "Update" : "Save") Product
                </SfButton>
                <SfButton CssClass="e-outline" IconCss="e-icons e-refresh" @onclick="ClearForm">Clear</SfButton>
                <SfButton CssClass="e-outline" IconCss="e-icons e-arrow-left" @onclick="NavigateBack">Back to List</SfButton>
            </div>
        </EditForm>
    </CardContent>
</SfCard>

<SfToast @ref="toast" Title="Success" Content="@toastMessage" Timeout="3000">
    <ToastPosition X="Right" Y="Top"></ToastPosition>
</SfToast>

@code {
    [Parameter]
    public int? ProductId { get; set; }

    private ProductModel product = new ProductModel();
    private SfToast? toast;
    private string toastMessage = "";
    private List<string> categories = new List<string> 
    { 
        "Beverages", 
        "Stationery", 
        "Grocery", 
        "Electronics",
        "Clothing"
    };

    protected override void OnParametersSet()
    {
        if (ProductId.HasValue)
        {
            LoadProduct(ProductId.Value);
        }
    }

    private void LoadProduct(int id)
    {
        product = new ProductModel
        {
            Name = "Sample Product",
            SKU = "SKU-001",
            Category = "Beverages",
            Price = 10.50m,
            Stock = 50,
            ReorderLevel = 10,
            Description = "Sample description",
            ImageUrl = "https://via.placeholder.com/300x200?text=Product",
            IsActive = true
        };
    }

    private async Task HandleSubmit()
    {
        toastMessage = $"Product {(ProductId.HasValue ? "updated" : "saved")} successfully!";
        await toast!.ShowAsync();
        
        await Task.Delay(2000);
        Navigation.NavigateTo("/products");
    }

    private void ClearForm()
    {
        product = new ProductModel();
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/products");
    }

    private void OnFileSelected(UploadChangeEventArgs args)
    {
        if (args.Files.Count > 0)
        {
            product.ImageUrl = "https://via.placeholder.com/300x200?text=Uploaded+Image";
        }
    }

    public class ProductModel
    {
        [Required(ErrorMessage = "Product name is required")]
        public string Name { get; set; } = string.Empty;
        
        public string SKU { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "Category is required")]
        public string Category { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "Price is required")]
        [Range(0.01, double.MaxValue, ErrorMessage = "Price must be greater than 0")]
        public decimal? Price { get; set; }
        
        [Required(ErrorMessage = "Stock quantity is required")]
        [Range(0, int.MaxValue, ErrorMessage = "Stock must be 0 or greater")]
        public int? Stock { get; set; }
        
        public int? ReorderLevel { get; set; }
        public string Description { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}

<style>
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        margin-bottom: 8px;
        font-weight: 500;
        color: #212529;
    }

    .required {
        color: #dc3545;
    }

    .validation-message {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 4px;
    }

    .image-preview {
        margin-top: 10px;
        width: 300px;
        height: 200px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid #dee2e6;
    }

    .image-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .image-preview {
            width: 100%;
            max-width: 300px;
        }

        .form-actions {
            flex-direction: column;
        }

        .form-actions .e-btn {
            width: 100%;
        }
    }
</style>
