@page "/product-form"
@page "/product-form/{ProductId:int}"

<div class="product-form-page">
    <SfCard>
        <CardHeader Title="@(ProductId.HasValue ? "Edit Product" : "Add New Product")" />
        <CardContent>
            <EditForm Model="@product" OnValidSubmit="HandleSubmit">
                <div class="form-group">
                    <label>Product Name</label>
                    <SfTextBox @bind-Value="@product.Name" Placeholder="Enter product name"></SfTextBox>
                </div>

                <div class="form-group">
                    <label>Category</label>
                    <SfDropDownList TValue="string" TItem="string" @bind-Value="@product.Category" 
                                   DataSource="@categories" Placeholder="Select category">
                    </SfDropDownList>
                </div>

                <div class="form-group">
                    <label>Price</label>
                    <SfNumericTextBox TValue="decimal?" @bind-Value="@product.Price" 
                                     Format="C2" Placeholder="0.00" Min="0">
                    </SfNumericTextBox>
                </div>

                <div class="form-group">
                    <label>Stock Quantity</label>
                    <SfNumericTextBox TValue="int?" @bind-Value="@product.Stock" 
                                     Placeholder="0" Min="0">
                    </SfNumericTextBox>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <SfTextBox @bind-Value="@product.Description" Multiline="true" 
                              Placeholder="Enter product description"></SfTextBox>
                </div>

                <div class="form-group">
                    <SfCheckBox @bind-Checked="@product.IsActive" Label="Active"></SfCheckBox>
                </div>

                <div class="form-actions">
                    <SfButton Type="ButtonType.Submit" CssClass="e-primary" IconCss="e-icons e-save">@(ProductId.HasValue ? "Update" : "Save") Product</SfButton>
                    <SfButton CssClass="e-outline" IconCss="e-icons e-close" @onclick="ClearForm">Clear</SfButton>
                    <SfButton CssClass="e-outline" IconCss="e-icons e-arrow-left" @onclick="NavigateBack">Back to List</SfButton>
                </div>
            </EditForm>

            @if (showSuccess)
            {
                <SfMessage Severity="MessageSeverity.Success">Product @(ProductId.HasValue ? "updated" : "saved") successfully!</SfMessage>
            }
        </CardContent>
    </SfCard>
</div>

@code {
    [Parameter]
    public int? ProductId { get; set; }

    [Inject]
    private NavigationManager? Navigation { get; set; }

    private ProductModel product = new ProductModel();
    private bool showSuccess = false;
    private List<string> categories = new List<string> 
    { 
        "Beverages", 
        "Stationery", 
        "Grocery", 
        "Electronics",
        "Clothing"
    };

    protected override void OnParametersSet()
    {
        if (ProductId.HasValue)
        {
            LoadProduct(ProductId.Value);
        }
    }

    private void LoadProduct(int id)
    {
        // Simulate loading product data
        product = new ProductModel
        {
            Name = "Sample Product",
            Category = "Beverages",
            Price = 10.50m,
            Stock = 50,
            Description = "Sample description",
            IsActive = true
        };
    }

    private void HandleSubmit()
    {
        showSuccess = true;
        StateHasChanged();
        Task.Delay(2000).ContinueWith(_ => 
        {
            showSuccess = false;
            InvokeAsync(() =>
            {
                Navigation?.NavigateTo("/products");
            });
        });
    }

    private void ClearForm()
    {
        product = new ProductModel();
        showSuccess = false;
    }

    private void NavigateBack()
    {
        Navigation?.NavigateTo("/products");
    }

    public class ProductModel
    {
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public decimal? Price { get; set; }
        public int? Stock { get; set; }
        public string Description { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}

<style>
    .product-form-page {
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 500;
        color: #212529;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }
</style>
