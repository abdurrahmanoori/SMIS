@page "/products"
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Data
@using Syncfusion.Blazor.Grids
@using GridSelectionType = Syncfusion.Blazor.Grids.SelectionType

<div class="products-page">
    <SfCard>
        <CardHeader Title="Product Management" />
        <CardContent>
            <div class="card-actions">
                <SfButton CssClass="e-primary" IconCss="e-icons e-plus" @onclick="OpenAddDialog">Add Product</SfButton>
                <SfButton CssClass="e-success" IconCss="e-icons e-export-excel" @onclick="ExportToExcel">Export Excel</SfButton>
                <SfButton CssClass="e-warning" IconCss="e-icons e-export-pdf" @onclick="ExportToPdf">Export PDF</SfButton>
                <SfButton CssClass="e-info" IconCss="e-icons e-refresh" @onclick="RefreshGrid">Refresh</SfButton>
            </div>

            <div class="search-bar">
                <SfTextBox Placeholder="Search products..." Value="@searchText" CssClass="search-input">
                    <TextBoxEvents Input="@OnSearchInput"></TextBoxEvents>
                </SfTextBox>
            </div>

            <SfGrid @ref="grid" DataSource="@filteredProducts" AllowPaging="true" AllowSorting="true" AllowFiltering="true" 
                    AllowExcelExport="true" AllowPdfExport="true" AllowSelection="true" Toolbar="@toolbarItems" ShowColumnChooser="true"
                    AllowResizing="true">
                <GridPageSettings PageSize="10"></GridPageSettings>
                <GridSelectionSettings Type="GridSelectionType.Multiple"></GridSelectionSettings>
                <GridColumns>
                    <GridColumn Type="ColumnType.CheckBox" Width="50" MinWidth="50" HideAtMedia="(max-width: 768px)"></GridColumn>
                    <GridColumn Field="@nameof(Product.Id)" HeaderText="ID" Width="80" MinWidth="60" HideAtMedia="(max-width: 768px)"></GridColumn>
                    <GridColumn Field="@nameof(Product.Name)" HeaderText="Product Name" Width="150" MinWidth="120"></GridColumn>
                    <GridColumn Field="@nameof(Product.Category)" HeaderText="Category" Width="120" MinWidth="100" HideAtMedia="(max-width: 576px)"></GridColumn>
                    <GridColumn Field="@nameof(Product.Price)" HeaderText="Price" Format="C2" Width="100" MinWidth="80"></GridColumn>
                    <GridColumn Field="@nameof(Product.Stock)" HeaderText="Stock" Width="80" MinWidth="70" HideAtMedia="(max-width: 576px)">
                        <Template>
                            @{
                                var product = (context as Product)!;
                                var stockClass = product.Stock < 20 ? "low-stock" : product.Stock < 50 ? "medium-stock" : "high-stock";
                                <SfChip CssClass="@stockClass">@product.Stock</SfChip>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(Product.IsActive)" HeaderText="Active" DisplayAsCheckBox="true" Width="80" MinWidth="70" HideAtMedia="(max-width: 992px)"></GridColumn>
                    <GridColumn HeaderText="Actions" Width="180" MinWidth="120">
                        <Template>
                            @{
                                var product = (context as Product)!;
                                <div class="action-buttons">
                                    <SfButton CssClass="e-small" IconCss="e-icons e-eye" @onclick="() => OpenQuickView(product)" Title="Quick View"></SfButton>
                                    <SfButton CssClass="e-small e-info" IconCss="e-icons e-edit" @onclick="() => OpenEditDialog(product)" Title="Edit"></SfButton>
                                    <SfButton CssClass="e-small e-danger" IconCss="e-icons e-delete" @onclick="() => OpenDeleteDialog(product)" Title="Delete"></SfButton>
                                </div>
                            }
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        </CardContent>
    </SfCard>
</div>

@if (showQuickView && selectedProduct != null)
{
    <SfDialog @bind-Visible="@showQuickView" Width="500px" IsModal="true" ShowCloseIcon="true">
        <DialogTemplates>
            <Header>
                <div class="dialog-header-content">
                    <span class="e-icons e-eye"></span>
                    <span>Product Details</span>
                </div>
            </Header>
            <Content>
                <div class="quick-view-panel">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/450x250?text=@selectedProduct.Name" alt="@selectedProduct.Name" />
                    </div>
                    <div class="product-details">
                        <div class="detail-row">
                            <strong>Product Name:</strong> <span class="detail-value">@selectedProduct.Name</span>
                        </div>
                        <div class="detail-row">
                            <strong>ID:</strong> <span class="detail-value">@selectedProduct.Id</span>
                        </div>
                        <div class="detail-row">
                            <strong>Category:</strong> <SfChip>@selectedProduct.Category</SfChip>
                        </div>
                        <div class="detail-row">
                            <strong>Price:</strong> <span class="price">@selectedProduct.Price.ToString("C2")</span>
                        </div>
                        <div class="detail-row">
                            <strong>Stock:</strong> 
                            @{
                                var stockClass = selectedProduct.Stock < 20 ? "low-stock" : selectedProduct.Stock < 50 ? "medium-stock" : "high-stock";
                                <SfChip CssClass="@stockClass">@selectedProduct.Stock units</SfChip>
                            }
                        </div>
                        <div class="detail-row">
                            <strong>Status:</strong> 
                            <SfChip CssClass="@(selectedProduct.IsActive ? "active-chip" : "inactive-chip")">@(selectedProduct.IsActive ? "Active" : "Inactive")</SfChip>
                        </div>
                    </div>
                    <div class="quick-actions">
                        <SfButton CssClass="e-primary" IconCss="e-icons e-edit" @onclick="() => { CloseQuickView(); OpenEditDialog(selectedProduct); }">Edit Product</SfButton>
                        <SfButton CssClass="e-danger" IconCss="e-icons e-delete" @onclick="() => { CloseQuickView(); OpenDeleteDialog(selectedProduct); }">Delete Product</SfButton>
                    </div>
                </div>
            </Content>
        </DialogTemplates>
    </SfDialog>
}

<SfDialog @bind-Visible="@showDialog" Width="500px" IsModal="true">
    <DialogTemplates>
        <Header>@dialogTitle</Header>
        <Content>
            <EditForm Model="@currentProduct" OnValidSubmit="SaveProduct">
                <div class="form-group">
                    <label>Product Name</label>
                    <SfTextBox @bind-Value="@currentProduct.Name" Placeholder="Enter product name"></SfTextBox>
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <SfDropDownList TValue="string" TItem="string" @bind-Value="@currentProduct.Category" 
                                   DataSource="@categories" Placeholder="Select category">
                    </SfDropDownList>
                </div>
                <div class="form-group">
                    <label>Price</label>
                    <SfNumericTextBox TValue="decimal" @bind-Value="@currentProduct.Price" 
                                     Format="C2" Placeholder="0.00" Min="0">
                    </SfNumericTextBox>
                </div>
                <div class="form-group">
                    <label>Stock Quantity</label>
                    <SfNumericTextBox TValue="int" @bind-Value="@currentProduct.Stock" 
                                     Placeholder="0" Min="0">
                    </SfNumericTextBox>
                </div>
                <div class="form-group">
                    <SfCheckBox @bind-Checked="@currentProduct.IsActive" Label="Active"></SfCheckBox>
                </div>
                <div class="dialog-actions">
                    <SfButton Type="ButtonType.Submit" CssClass="e-primary" IconCss="e-icons e-save">Save</SfButton>
                    <SfButton CssClass="e-outline" @onclick="CloseDialog">Cancel</SfButton>
                </div>
            </EditForm>
        </Content>
    </DialogTemplates>
</SfDialog>

<SfDialog @bind-Visible="@showDeleteDialog" Width="400px" IsModal="true">
    <DialogTemplates>
        <Header>Confirm Delete</Header>
        <Content>
            <p>Are you sure you want to delete <strong>@productToDelete?.Name</strong>?</p>
            <div class="dialog-actions">
                <SfButton CssClass="e-danger" IconCss="e-icons e-delete" @onclick="ConfirmDelete">Delete</SfButton>
                <SfButton CssClass="e-outline" @onclick="CloseDeleteDialog">Cancel</SfButton>
            </div>
        </Content>
    </DialogTemplates>
</SfDialog>

@code {
    private SfGrid<Product>? grid;
    private List<Product> products = new List<Product>
    {
        new Product { Id = 1, Name = "Coca Cola", Category = "Beverages", Price = 1.50m, Stock = 15, IsActive = true },
        new Product { Id = 2, Name = "Pepsi", Category = "Beverages", Price = 1.45m, Stock = 85, IsActive = true },
        new Product { Id = 3, Name = "Notebook", Category = "Stationery", Price = 2.50m, Stock = 45, IsActive = true },
        new Product { Id = 4, Name = "Pen", Category = "Stationery", Price = 0.75m, Stock = 200, IsActive = true },
        new Product { Id = 5, Name = "Rice", Category = "Grocery", Price = 15.00m, Stock = 8, IsActive = true },
        new Product { Id = 6, Name = "Sprite", Category = "Beverages", Price = 1.40m, Stock = 120, IsActive = true },
        new Product { Id = 7, Name = "Eraser", Category = "Stationery", Price = 0.50m, Stock = 150, IsActive = false },
    };

    private List<Product> filteredProducts = new List<Product>();
    private List<string> categories = new List<string> { "Beverages", "Stationery", "Grocery", "Electronics", "Clothing" };
    private List<object> toolbarItems = new List<object> { "ColumnChooser" };
    private bool showDialog = false;
    private bool showDeleteDialog = false;
    private bool showQuickView = false;
    private string dialogTitle = "";
    private string searchText = "";
    private Product currentProduct = new Product();
    private Product? productToDelete;
    private Product? selectedProduct;
    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        filteredProducts = products.ToList();
        showQuickView = false; // Ensure sidebar starts closed
    }

    private void OnSearchInput(InputEventArgs args)
    {
        searchText = args.Value;
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredProducts = products.ToList();
        }
        else
        {
            filteredProducts = products.Where(p => 
                p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                p.Category.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }
        StateHasChanged();
    }

    private void OpenQuickView(Product product)
    {
        selectedProduct = product;
        showQuickView = true;
        StateHasChanged();
    }

    private void CloseQuickView()
    {
        showQuickView = false;
        selectedProduct = null;
        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        if (grid != null)
        {
            await grid.ExcelExport();
        }
    }

    private async Task ExportToPdf()
    {
        if (grid != null)
        {
            await grid.PdfExport();
        }
    }

    private void OpenAddDialog()
    {
        dialogTitle = "Add New Product";
        currentProduct = new Product { IsActive = true };
        isEditMode = false;
        showDialog = true;
    }

    private void OpenEditDialog(Product product)
    {
        dialogTitle = "Edit Product";
        currentProduct = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Category = product.Category,
            Price = product.Price,
            Stock = product.Stock,
            IsActive = product.IsActive
        };
        isEditMode = true;
        showDialog = true;
    }

    private void OpenDeleteDialog(Product product)
    {
        productToDelete = product;
        showDeleteDialog = true;
    }

    private void SaveProduct()
    {
        if (isEditMode)
        {
            var existing = products.FirstOrDefault(p => p.Id == currentProduct.Id);
            if (existing != null)
            {
                existing.Name = currentProduct.Name;
                existing.Category = currentProduct.Category;
                existing.Price = currentProduct.Price;
                existing.Stock = currentProduct.Stock;
                existing.IsActive = currentProduct.IsActive;
            }
        }
        else
        {
            currentProduct.Id = products.Any() ? products.Max(p => p.Id) + 1 : 1;
            products.Add(currentProduct);
        }
        CloseDialog();
        RefreshFilteredProducts();
    }

    private void ConfirmDelete()
    {
        if (productToDelete != null)
        {
            products.Remove(productToDelete);
            RefreshFilteredProducts();
        }
        CloseDeleteDialog();
    }

    private void RefreshFilteredProducts()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredProducts = products.ToList();
        }
        else
        {
            filteredProducts = products.Where(p => 
                p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                p.Category.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }
        StateHasChanged();
    }

    private void CloseDialog()
    {
        showDialog = false;
        currentProduct = new Product();
    }

    private void CloseDeleteDialog()
    {
        showDeleteDialog = false;
        productToDelete = null;
    }

    private void RefreshGrid()
    {
        filteredProducts = products.ToList();
        searchText = "";
        StateHasChanged();
    }

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int Stock { get; set; }
        public bool IsActive { get; set; }
    }
}

<style>
    .products-page {
        max-width: 1400px;
        padding: 10px;
    }

    .card-actions {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .search-bar {
        margin-bottom: 20px;
    }

    .search-input {
        width: 100%;
        max-width: 400px;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
    }

    .dialog-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .low-stock {
        background-color: #dc3545 !important;
        color: white !important;
    }

    .medium-stock {
        background-color: #ffc107 !important;
        color: black !important;
    }

    .high-stock {
        background-color: #28a745 !important;
        color: white !important;
    }

    .quick-view-panel {
        padding: 0;
    }

    .dialog-header-content {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .product-image {
        margin-bottom: 20px;
        text-align: center;
    }

    .product-image img {
        width: 100%;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .product-details {
        margin-bottom: 20px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .detail-row strong {
        color: #666;
        font-size: 0.95rem;
        min-width: 120px;
    }

    .detail-row .detail-value {
        color: #333;
        font-weight: 500;
    }

    .detail-row .price {
        font-size: 1.3rem;
        font-weight: bold;
        color: #28a745;
    }

    .quick-actions {
        display: flex;
        gap: 10px;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 2px solid #f0f0f0;
        justify-content: center;
    }

    .active-chip {
        background-color: #28a745 !important;
        color: white !important;
    }

    .inactive-chip {
        background-color: #6c757d !important;
        color: white !important;
    }

    /* Mobile Responsive Styles */
    @@media (max-width: 768px) {
        .products-page {
            padding: 5px;
        }

        .card-actions {
            gap: 5px;
        }

        .card-actions .e-btn {
            font-size: 12px;
            padding: 6px 10px;
        }

        .search-input {
            max-width: 100%;
        }

        .action-buttons {
            gap: 3px;
        }

        .action-buttons .e-btn {
            min-width: 32px;
            padding: 4px;
        }

        .e-dialog {
            width: 95% !important;
            max-width: 95% !important;
        }

        .dialog-actions {
            justify-content: stretch;
        }

        .dialog-actions .e-btn {
            flex: 1;
        }

        .quick-actions {
            flex-direction: column;
        }

        .quick-actions .e-btn {
            width: 100%;
        }

        .detail-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 5px;
        }

        .detail-row strong {
            min-width: auto;
        }
    }

    @@media (max-width: 576px) {
        .product-image {
            margin-bottom: 15px;
        }

        .detail-row .price {
            font-size: 1.1rem;
        }

        .e-grid .e-gridcontent {
            overflow-x: auto;
        }
    }
</style>
