@using SMIS.UI2.Services
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject AuthServiceWrapper AuthService
@inject NavigationManager Navigation
@implements IDisposable

<div class="page-container">
    <SfSidebar @ref="sidebar" Width="250px" Type="SidebarType.Auto" @bind-IsOpen="isSidebarOpen" CloseOnDocumentClick="false">
        <ChildContent>
            <div class="sidebar-content">
                <div class="sidebar-header">
                    <h3>SMIS</h3>
                </div>
                <NavMenu />
            </div>
        </ChildContent>
    </SfSidebar>

    <div class="main-content">
        <div class="header">
            <SfButton CssClass="e-flat" IconCss="e-icons e-menu" @onclick="ToggleSidebar"></SfButton>
            <h4>Shop Management System</h4>
            <div class="header-actions">
                <SfButton CssClass="e-flat e-danger" IconCss="e-icons e-logout" OnClick="Logout" title="Logout">Logout</SfButton>
            </div>
        </div>
        <div class="content">
            @Body
        </div>
    </div>
</div>

@code {
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        var res = await AuthService.IsAuthenticatedAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private SfSidebar? sidebar;
    private bool isSidebarOpen = true;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("setupResizeListener", objRef);
        }
    }

    [JSInvokable]
    public void CloseSidebarFromJS()
    {
        if (isSidebarOpen)
        {
            isSidebarOpen = false;
            StateHasChanged();
        }
    }

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}

<style>
    .page-container {
        display: flex;
        height: 100vh;
        overflow: hidden;
    }

    .sidebar-content {
        height: 100%;
        background-color: #f8f9fa;
    }

    .sidebar-header {
        padding: 20px;
        background-color: #0d6efd;
        color: white;
        text-align: center;
    }

    .sidebar-header h3 {
        margin: 0;
    }

    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .header {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 20px;
        background-color: #fff;
        border-bottom: 1px solid #dee2e6;
        justify-content: space-between;
    }

    .header-actions {
        margin-left: auto;
    }

    .header h4 {
        margin: 0;
    }

    .content {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
    }
</style>
