@if (HasError)
{
    <div class="validation-message">@ErrorMessage</div>
}

@code {
    [Parameter]
    public Dictionary<string, string>? ValidationErrors { get; set; }

    [Parameter]
    public string PropertyName { get; set; } = string.Empty;

    private bool HasError => ValidationErrors?.ContainsKey(PropertyName) ?? false;

    private string ErrorMessage => ValidationErrors?.TryGetValue(PropertyName, out var message) == true ? message : string.Empty;
}

<style>
    .validation-message {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 4px;
    }
</style>
