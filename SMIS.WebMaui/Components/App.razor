<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link id="syncfusion-theme" href="https://cdn.syncfusion.com/blazor/27.1.48/styles/bootstrap5.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["SMIS.WebMaui.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="https://cdn.syncfusion.com/blazor/27.1.48/syncfusion-blazor.min.js" type="text/javascript"></script>
    <script>
        window.setupResizeListener = function (dotnetHelper) {
            window.mainLayoutRef = dotnetHelper;
            window.addEventListener('resize', function () {
                if (window.innerWidth <= 768 && window.mainLayoutRef) {
                    window.mainLayoutRef.invokeMethodAsync('CloseSidebarFromJS');
                }
            });
        };

        window.themeInterop = {
            setTheme: function (isDark) {
                var link = document.getElementById('syncfusion-theme');
                var base = 'https://cdn.syncfusion.com/blazor/27.1.48/styles/';
                link.href = isDark ? base + 'bootstrap5-dark.css' : base + 'bootstrap5.css';
                document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
                document.body.setAttribute('data-theme', isDark ? 'dark' : 'light');
            },
            getDevicePreference: function () {
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            },
            watchDevicePreference: function (dotnetHelper) {
                if (window.matchMedia) {
                    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
                        dotnetHelper.invokeMethodAsync('OnDeviceThemeChanged', e.matches);
                    });
                }
            }
        };
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
