@inject NavigationManager Navigation
@using SMIS.UI.Middleware
@using SMIS.Application.Common.Exceptions
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Notifications

<div class="error-overlay">
    <div class="error-wrapper">
        <SfCard>
            <CardHeader>
                <span class="e-icons e-warning error-header-icon"></span>
                <span class="error-header-title">An Error Occurred</span>
            </CardHeader>
            <CardContent>
                <SfMessage Severity="MessageSeverity.Error" ShowCloseIcon="false">
                    @if (_isDebug)
                    {
                        <strong>@Exception.GetType().FullName</strong>
                        <p>@Exception.Message</p>
                    }
                    else
                    {
                        <p>An unexpected error occurred. Please try again or contact support if the problem persists.</p>
                    }
                </SfMessage>

                @if (_isDebug)
                {
                    <div class="error-meta">
                        @if (Exception.InnerException != null)
                        {
                            <SfMessage Severity="MessageSeverity.Warning" ShowCloseIcon="false">
                                <strong>Inner Exception:</strong> @Exception.InnerException.GetType().Name: @Exception.InnerException.Message
                            </SfMessage>
                        }

                        <div class="meta-row">
                            <SfChip>
                                <ChipItems>
                                    <ChipItem Text="@($"Source: {Exception.Source ?? "N/A"}")" CssClass="e-outline"></ChipItem>
                                    <ChipItem Text="@($"Time: {DateTime.Now:yyyy-MM-dd HH:mm:ss}")" CssClass="e-outline"></ChipItem>
                                </ChipItems>
                            </SfChip>
                        </div>

                        @if (!string.IsNullOrEmpty(Exception.StackTrace))
                        {
                            <div class="stack-trace-block">
                                <strong>Stack Trace:</strong>
                                <pre>@Exception.StackTrace</pre>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="meta-row">
                        <SfChip>
                            <ChipItems>
                                <ChipItem Text="@($"Time: {DateTime.Now:yyyy-MM-dd HH:mm:ss}")" CssClass="e-outline"></ChipItem>
                            </ChipItems>
                        </SfChip>
                    </div>
                }
            </CardContent>
            <CardFooter>
                <div class="error-actions">
                    <SfButton CssClass="e-primary" IconCss="e-icons e-refresh" @onclick="HandleReload">Reload</SfButton>
                    <SfButton CssClass="e-outline" IconCss="e-icons e-home" @onclick="@(() => Navigation.NavigateTo("/"))">Go Home</SfButton>
                </div>
            </CardFooter>
        </SfCard>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Exception Exception { get; set; } = default!;
    [Parameter] public EventCallback OnReload { get; set; }

#if DEBUG
    private readonly bool _isDebug = true;
#else
    private readonly bool _isDebug = false;
#endif

    protected override void OnInitialized()
    {
        GlobalExceptionHandler.HandleException(Exception, showAlert: false);
    }

    private async Task HandleReload()
    {
        if (OnReload.HasDelegate)
            await OnReload.InvokeAsync();
        else
            Navigation.NavigateTo("/", forceLoad: true);
    }
}

<style>
    .error-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        padding: 20px;
    }

    .error-wrapper {
        width: 100%;
        max-width: 700px;
        max-height: 90vh;
        overflow-y: auto;
    }

    .error-header-icon {
        font-size: 22px;
        color: #dc3545;
        margin-right: 10px;
        vertical-align: middle;
    }

    .error-header-title {
        font-size: 18px;
        font-weight: 600;
        vertical-align: middle;
    }

    .error-meta {
        margin-top: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .meta-row {
        margin-top: 12px;
    }

    .stack-trace-block {
        margin-top: 8px;
    }

    .stack-trace-block pre {
        background: #f5f5f5;
        padding: 12px;
        border-radius: 4px;
        font-size: 11px;
        line-height: 1.5;
        overflow-x: auto;
        margin-top: 6px;
        color: #333;
    }

    .error-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        padding: 4px 0;
    }

    [data-theme="dark"] .stack-trace-block pre {
        background: #2a2a3a;
        color: #e0e0e0;
    }
</style>
