@using SMIS.UI.Services.Interfaces
@inject IUiAuthService AuthService
@inject NavigationManager Navigation

@if (_isChecking)
{
    <div class="auth-checking">
        <SfSpinner Visible="true" Size="40"></SfSpinner>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _isChecking = true;
    private static readonly string[] PublicRoutes = ["/login"];

    protected override async Task OnInitializedAsync()
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath.ToLower();

        if (PublicRoutes.Contains(currentPath))
        {
            _isChecking = false;
            return;
        }

        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
            Navigation.NavigateTo("/login", replace: true);

        _isChecking = false;
    }
}

<style>
    .auth-checking {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }
</style>
