@page "/categories"
@using SMIS.UI.Shared.Services.Interfaces
@using SMIS.UI.Shared.Helpers
@using SMIS.Application.DTO.Categories
@using SMIS.Application.Common.Response
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Inputs
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<SfCard>
    <CardHeader Title="Category Management" />
    <CardContent>
        <div class="card-actions">
            <SfButton CssClass="e-primary" IconCss="e-icons e-plus" @onclick="OpenAddDialog">Add Category</SfButton>
            <SfButton CssClass="e-success" IconCss="e-icons e-export-excel" @onclick="ExportToExcel">Export Excel</SfButton>
            <SfButton CssClass="e-warning" IconCss="e-icons e-export-pdf" @onclick="ExportToPdf">Export PDF</SfButton>
            <div class="sync-btn-wrapper">
                <SfButton CssClass="e-info" IconCss="e-icons e-sync" @onclick="SyncData">Sync</SfButton>
                @if (_pendingCount > 0)
                {
                    <span class="pending-badge">@_pendingCount</span>
                }
            </div>
            <SfButton CssClass="e-success" IconCss="e-icons e-refresh" @onclick="RefreshGrid">Refresh</SfButton>
        </div>

        <div class="search-wrapper">
            <input type="text" placeholder="Search categories..." class="e-input" value="@searchText"
                   @oninput="@(async (e) => await OnSearchInput(e))" />
            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <span @onclick="ClearSearch" class="e-icons e-close search-clear"></span>
            }
        </div>

        @if (_isLoading)
        {
            <div class="loading-container">
                <SfSpinner></SfSpinner>
            </div>
        }
        else
        {
            <SfGrid @ref="grid" DataSource="@_categories" AllowPaging="false" AllowSorting="true" AllowFiltering="true"
                    AllowExcelExport="true" AllowPdfExport="true" AllowSelection="true" Toolbar="@toolbarItems"
                    ShowColumnChooser="true" AllowResizing="true" Height="400px">
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Menu"></GridFilterSettings>
                <GridColumns>
                    <GridColumn Field="@nameof(CategoryDto.Name)" HeaderText="Name" Width="150"></GridColumn>
                    <GridColumn Field="@nameof(CategoryDto.Code)" HeaderText="Code" Width="100"></GridColumn>
                    <GridColumn Field="@nameof(CategoryDto.Description)" HeaderText="Description" Width="200"></GridColumn>
                    <GridColumn Field="@nameof(CategoryDto.IsActive)" HeaderText="Active" DisplayAsCheckBox="true" Width="80"></GridColumn>
                    <GridColumn HeaderText="Actions" Width="150">
                        <Template>
                            @{
                                var category = (context as CategoryDto)!;
                                <div class="action-buttons">
                                    <SfButton CssClass="e-small" IconCss="e-icons e-eye" @onclick="() => OpenQuickView(category)" Title="Quick View"></SfButton>
                                    <SfButton CssClass="e-small e-info" IconCss="e-icons e-edit" @onclick="() => OpenEditDialog(category)" Title="Edit"></SfButton>
                                    <SfButton CssClass="e-small e-danger" IconCss="e-icons e-delete" @onclick="() => OpenDeleteConfirm(category)" Title="Delete"></SfButton>
                                </div>
                            }
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>

            <SfPager PageSize="@_pageSize" TotalItemsCount="@_totalCount" CurrentPage="@_currentPage"
                     PageChanged="OnPageChanged">
            </SfPager>
        }
    </CardContent>
</SfCard>

<SfDialog @bind-Visible="@showQuickView" Width="500px" IsModal="true" ShowCloseIcon="true">
    <DialogTemplates>
        <Header>
            <span class="e-icons e-eye"></span>
            <span>Category Details</span>
        </Header>
        <Content>
            @if (selectedCategory != null)
            {
                <div class="detail-row">
                    <strong>Category Name:</strong> <span>@selectedCategory.Name</span>
                </div>
                <div class="detail-row">
                    <strong>Code:</strong> <span>@(selectedCategory.Code ?? "N/A")</span>
                </div>
                <div class="detail-row">
                    <strong>Description:</strong> <span>@(selectedCategory.Description ?? "N/A")</span>
                </div>
                <div class="detail-row">
                    <strong>Status:</strong>
                    <SfChip CssClass="@(selectedCategory.IsActive ? "active-chip" : "inactive-chip")">
                        @(selectedCategory.IsActive ? "Active" : "Inactive")
                    </SfChip>
                </div>
                <div class="quick-actions">
                    <SfButton CssClass="e-primary" IconCss="e-icons e-edit" @onclick="() => { CloseQuickView(); OpenEditDialog(selectedCategory); }">Edit</SfButton>
                    <SfButton CssClass="e-danger" IconCss="e-icons e-delete" @onclick="() => { CloseQuickView(); OpenDeleteConfirm(selectedCategory); }">Delete</SfButton>
                </div>
            }
        </Content>
    </DialogTemplates>
</SfDialog>

<SfDialog @bind-Visible="@showDialog" Width="500px" IsModal="true">
    <DialogTemplates>
        <Header>@dialogTitle</Header>
        <Content>
            <EditForm Model="@currentCategory" OnValidSubmit="SaveCategory">
                <div class="form-group">
                    <label>Category Name <span class="required">*</span></label>
                    <SfTextBox @bind-Value="@currentCategory.Name" Placeholder="Enter category name"></SfTextBox>
                    @if (validationErrors.ContainsKey(nameof(CategoryCreateDto.Name)))
                    {
                        <div class="validation-message">@validationErrors[nameof(CategoryCreateDto.Name)]</div>
                    }
                </div>
                <div class="form-group">
                    <label>Code</label>
                    <SfTextBox @bind-Value="@currentCategory.Code" Placeholder="Enter category code"></SfTextBox>
                    @if (validationErrors.ContainsKey(nameof(CategoryCreateDto.Code)))
                    {
                        <div class="validation-message">@validationErrors[nameof(CategoryCreateDto.Code)]</div>
                    }
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <SfTextBox @bind-Value="@currentCategory.Description" Multiline="true" Placeholder="Enter description"></SfTextBox>
                    @if (validationErrors.ContainsKey(nameof(CategoryCreateDto.Description)))
                    {
                        <div class="validation-message">@validationErrors[nameof(CategoryCreateDto.Description)]</div>
                    }
                </div>
                <div class="form-group">
                    <SfCheckBox @bind-Checked="@currentCategory.IsActive" Label="Active"></SfCheckBox>
                </div>
                <div class="dialog-actions">
                    <SfButton Type="ButtonType.Submit" CssClass="e-primary" IconCss="e-icons e-save">Save</SfButton>
                    <SfButton CssClass="e-outline" @onclick="CloseDialog">Cancel</SfButton>
                </div>
            </EditForm>
        </Content>
    </DialogTemplates>
</SfDialog>

<SfDialog @bind-Visible="@showDeleteConfirm" Width="400px" IsModal="true" ShowCloseIcon="true">
    <DialogTemplates>
        <Header>
            <span class="e-icons e-warning delete-warning-icon"></span> Confirm Delete
        </Header>
        <Content>
            <p>Are you sure you want to delete <strong>@categoryToDelete?.Name</strong>?</p>
            <p class="delete-hint">This will be synced to the server on next sync.</p>
        </Content>
        <FooterTemplate>
            <div class="dialog-actions">
                <SfButton CssClass="e-danger" IconCss="e-icons e-delete" @onclick="ConfirmDelete">Delete</SfButton>
                <SfButton CssClass="e-outline" @onclick="() => showDeleteConfirm = false">Cancel</SfButton>
            </div>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>

<SfToast @ref="ToastObj" ShowCloseButton="true">
    <ToastPosition X="Right" Y="Top"></ToastPosition>
</SfToast>

@code {
    private SfGrid<CategoryDto>? grid;
    private SfToast? ToastObj;
    private List<CategoryDto> _categories = new();
    private List<object> toolbarItems = new() { "ColumnChooser" };
    private Dictionary<string, string> validationErrors = new();
    private CategoryFormModel currentCategory = new();
    private CategoryDto? selectedCategory;
    private CategoryDto? categoryToDelete;
    private string dialogTitle = "";
    private string searchText = "";
    private bool _isLoading = true;
    private bool showDialog = false;
    private bool showQuickView = false;
    private bool showDeleteConfirm = false;
    private bool isEditMode = false;
    private int _pendingCount = 0;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private int _totalPages = 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCategories(), LoadPendingCount());
    }

    private async Task LoadPendingCount()
    {
        _pendingCount = await CategoryService.GetPendingCountAsync();
    }

    private async Task LoadCategories(string? searchTerm = null)
    {
        _isLoading = true;

        var result = await CategoryService.GetAllAsync(_currentPage, _pageSize, searchTerm);

        if (result.Success && result.Response != null)
        {
            _categories = result.Response.Items;
            _totalCount = result.Response.TotalCount;
            _totalPages = result.Response.TotalPages;
            _currentPage = result.Response.PageNumber;
        }
        else if (ToastObj != null)
        {
            await ToastHelper.ShowErrorAsync(ToastObj, result.Message ?? "Failed to load categories", "Category");
        }

        _isLoading = false;
    }

    private async Task OnPageChanged(PageChangedEventArgs args)
    {
        _currentPage = args.CurrentPage;
        await LoadCategories(string.IsNullOrWhiteSpace(searchText) ? null : searchText);
    }

    private async Task OnSearchInput(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        searchText = args.Value?.ToString() ?? "";
        _currentPage = 1;
        await LoadCategories(string.IsNullOrWhiteSpace(searchText) ? null : searchText);
    }

    private async Task ClearSearch()
    {
        searchText = "";
        _currentPage = 1;
        await LoadCategories();
    }

    private void OpenQuickView(CategoryDto category)
    {
        selectedCategory = category;
        showQuickView = true;
    }

    private void CloseQuickView()
    {
        showQuickView = false;
        selectedCategory = null;
    }

    private void OpenAddDialog()
    {
        dialogTitle = "Add New Category";
        currentCategory = new CategoryFormModel { IsActive = true };
        isEditMode = false;
        validationErrors.Clear();
        showDialog = true;
    }

    // Public wrapper for testability
    public void OpenAddDialogPublic() => OpenAddDialog();

    private void OpenEditDialog(CategoryDto category)
    {
        dialogTitle = "Edit Category";
        currentCategory = new CategoryFormModel
        {
            Id = category.Id,
            Name = category.Name,
            Code = category.Code,
            Description = category.Description,
            IsActive = category.IsActive
        };
        isEditMode = true;
        validationErrors.Clear();
        showDialog = true;
    }

    private void CloseDialog()
    {
        showDialog = false;
        currentCategory = new CategoryFormModel();
    }

    private async Task SaveCategory()
    {
        Result<CategoryDto> result;
        string successMessage;

        if (isEditMode)
        {
            var updateDto = new CategoryUpdateDto
            {
                Name = currentCategory.Name,
                Code = currentCategory.Code,
                Description = currentCategory.Description,
                IsActive = currentCategory.IsActive
            };
            result = await CategoryService.UpdateAsync(currentCategory.Id, updateDto);
            successMessage = "Category updated successfully";
        }
        else
        {
            var createDto = new CategoryCreateDto
            {
                Name = currentCategory.Name,
                Code = currentCategory.Code,
                Description = currentCategory.Description,
                IsActive = currentCategory.IsActive
            };
            result = await CategoryService.CreateAsync(createDto);
            successMessage = "Category created successfully";
        }

        if (result.Success)
        {
            await ToastHelper.ShowSuccessAsync(ToastObj!, successMessage, "Category");
            CloseDialog();
            await Task.WhenAll(LoadCategories(), LoadPendingCount());
        }
        else
        {
            validationErrors = ValidationHelper.ExtractValidationErrors(result);
            if (!validationErrors.Any())
                await ToastHelper.ShowErrorAsync(ToastObj!, result.Message ?? "Operation failed", "Error");
            StateHasChanged();
        }
    }

    // Public wrapper for testability
    public Task SaveCategoryPublic() => SaveCategory();

    private void OpenDeleteConfirm(CategoryDto category)
    {
        categoryToDelete = category;
        showDeleteConfirm = true;
    }

    // Public wrapper for testability — bUnit cannot click inside Syncfusion SfGrid row templates
    public void OpenDeleteConfirmPublic(CategoryDto category) => OpenDeleteConfirm(category);

    private async Task ConfirmDelete()
    {
        if (categoryToDelete == null) return;

        showDeleteConfirm = false;
        var result = await CategoryService.DeleteAsync(categoryToDelete.Id);

        if (result.Success)
        {
            await ToastHelper.ShowSuccessAsync(ToastObj!, $"{categoryToDelete.Name} deleted successfully", "Category");
            categoryToDelete = null;
            await Task.WhenAll(
                LoadCategories(string.IsNullOrWhiteSpace(searchText) ? null : searchText),
                LoadPendingCount());
        }
        else
        {
            await ToastHelper.ShowErrorAsync(ToastObj!, result.Message ?? "Delete failed", "Error");
        }
    }

    // Public wrapper for testability
    public Task ConfirmDeletePublic() => ConfirmDelete();

    private async Task SyncData()
    {
        await ToastHelper.ShowInfoAsync(ToastObj!, "Syncing...", "Category");
        var result = await CategoryService.SyncAsync();

        if (result.Success)
        {
            await ToastHelper.ShowSuccessAsync(ToastObj!, result.Message ?? "Sync completed", "Category");
            await Task.WhenAll(LoadCategories(), LoadPendingCount());
        }
        else
        {
            await ToastHelper.ShowErrorAsync(ToastObj!, result.Message ?? "Sync failed", "Category");
        }
    }

    // Public wrapper for testability
    public Task SyncDataPublic() => SyncData();

    private async Task RefreshGrid()
    {
        searchText = "";
        _currentPage = 1;
        await Task.WhenAll(LoadCategories(), LoadPendingCount());
    }

    private async Task ExportToExcel()
    {
        if (grid != null)
            await grid.ExportToExcelAsync();
    }

    private async Task ExportToPdf()
    {
        if (grid != null)
            await grid.ExportToPdfAsync();
    }

    private class CategoryFormModel
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Code { get; set; }
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
    }
}

<style>
    .card-actions {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .sync-btn-wrapper {
        position: relative;
        display: inline-flex;
    }

    .pending-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background-color: #dc3545;
        color: white;
        border-radius: 50%;
        min-width: 18px;
        height: 18px;
        font-size: 11px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        pointer-events: none;
    }

    .search-wrapper {
        position: relative;
        margin-bottom: 16px;
    }

        .search-wrapper .e-input {
            display: block;
            width: 100%;
            padding-right: 30px;
        }

    .search-clear {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #999;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 300px;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
        }

    .required {
        color: #dc3545;
    }

    .validation-message {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 4px;
    }

    .dialog-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        justify-content: flex-end;
    }

    .delete-warning-icon {
        color: #dc3545;
        margin-right: 8px;
    }

    .delete-hint {
        color: #6c757d;
        font-size: 0.875rem;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
    }

        .detail-row strong {
            color: #666;
            min-width: 120px;
        }

    .quick-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid #f0f0f0;
        justify-content: center;
    }

    .active-chip {
        background-color: #28a745 !important;
        color: white !important;
    }

    .inactive-chip {
        background-color: #6c757d !important;
        color: white !important;
    }

    @@media (max-width: 768px) {
        .card-actions .e-btn {
            font-size: 12px;
            padding: 6px 10px;
        }

        .action-buttons .e-btn {
            min-width: 32px;
            padding: 4px;
        }

        .e-dialog {
            width: 95% !important;
        }

        .dialog-actions .e-btn,
        .quick-actions .e-btn {
            flex: 1;
        }

        .quick-actions {
            flex-direction: column;
        }

        .detail-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 5px;
        }

            .detail-row strong {
                min-width: auto;
            }

    }
</style>
