@page "/"
@using SMIS.UI.Shared.Services.Interfaces
@using SMIS.UI.Shared.Helpers
@using Syncfusion.Blazor.Notifications
@inject ISyncFacade SyncFacade

<div class="home-page">
    <SfCard>
        <CardHeader Title="Welcome to SMIS" />
        <CardContent>
            <h2>Shop Management Information System</h2>
            <p>A comprehensive shop management solution with Syncfusion Blazor components.</p>
            
            <div class="feature-cards">
                <SfCard>
                    <CardContent>
                        <div class="feature-icon">📦</div>
                        <h4>Inventory Management</h4>
                        <p>Track products, stock levels, and batches with precision.</p>
                    </CardContent>
                </SfCard>

                <SfCard>
                    <CardContent>
                        <div class="feature-icon">🌍</div>
                        <h4>Multi-Language</h4>
                        <p>Built-in translation system supporting multiple languages.</p>
                    </CardContent>
                </SfCard>

                <SfCard>
                    <CardContent>
                        <div class="feature-icon">📱</div>
                        <h4>Cross-Platform</h4>
                        <p>Access from Android, iOS, Windows, and macOS.</p>
                    </CardContent>
                </SfCard>
            </div>

            <div class="action-buttons">
                <SfButton CssClass="e-primary e-large" IconCss="e-icons e-shopping-cart" @onclick="NavigateToProducts">View Products</SfButton>
                <SfButton CssClass="e-success e-large" IconCss="e-icons e-plus">Add New Product</SfButton>
                <div class="sync-btn-wrapper">
                    <SfButton CssClass="e-info e-large" IconCss="e-icons e-sync" OnClick="SyncAll" Disabled="@_isSyncing">Sync All</SfButton>
                    @if (_totalPending > 0)
                    {
                        <span class="pending-badge">@_totalPending</span>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_syncMessage))
            {
                <div class="sync-result @_syncResultCss">
                    @_syncMessage
                </div>
            }
        </CardContent>
    </SfCard>
</div>

@code {
    [Inject] private NavigationManager? Navigation { get; set; }

    private bool _isSyncing = false;
    private int _totalPending = 0;
    private string _syncMessage = "";
    private string _syncResultCss = "";

    protected override async Task OnInitializedAsync()
    {
        _totalPending = await SyncFacade.GetTotalPendingCountAsync();
    }

    private void NavigateToProducts()
    {
        Navigation?.NavigateTo("/products");
    }

    private async Task SyncAll()
    {
        _isSyncing = true;
        _syncMessage = "Syncing...";
        _syncResultCss = "sync-info";
        StateHasChanged();

        var result = await SyncFacade.SyncAllAsync();

        _isSyncing = false;
        _totalPending = await SyncFacade.GetTotalPendingCountAsync();

        if (result.Success)
        {
            _syncMessage = $"Sync complete — {result.TotalSynced} synced, {result.TotalFailed} failed";
            _syncResultCss = "sync-success";
        }
        else
        {
            _syncMessage = $"Sync failed — {result.TotalFailed} failed";
            _syncResultCss = "sync-error";
        }
    }
}

<style>
    .home-page {
        max-width: 1200px;
    }

    .home-page h2 {
        color: #0d6efd;
        margin-bottom: 10px;
    }

    .home-page p {
        color: #6c757d;
        font-size: 16px;
    }

    .feature-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .feature-icon {
        font-size: 48px;
        text-align: center;
        margin-bottom: 10px;
    }

    .feature-cards h4 {
        text-align: center;
        color: #212529;
        margin: 10px 0;
    }

    .feature-cards p {
        text-align: center;
        font-size: 14px;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        flex-wrap: wrap;
        align-items: center;
    }

    .sync-btn-wrapper {
        position: relative;
        display: inline-flex;
    }

    .pending-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background-color: #dc3545;
        color: white;
        border-radius: 50%;
        min-width: 18px;
        height: 18px;
        font-size: 11px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        pointer-events: none;
    }

    .sync-result {
        margin-top: 15px;
        padding: 10px 16px;
        border-radius: 4px;
        font-size: 14px;
    }

    .sync-success { background-color: #d4edda; color: #155724; }
    .sync-error   { background-color: #f8d7da; color: #721c24; }
    .sync-info    { background-color: #d1ecf1; color: #0c5460; }
</style>
