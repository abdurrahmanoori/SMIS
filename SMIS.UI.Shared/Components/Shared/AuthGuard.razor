@using SMIS.UI.Shared.Services.Interfaces
@inject IUiAuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

@if (_isChecking)
{
    <div class="auth-checking">
        <SfSpinner Visible="true" Size="40"></SfSpinner>
    </div>
}
else if (_isAuthenticated || _isPublicRoute)
{
    @ChildContent
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _isChecking = true;
    private bool _isAuthenticated = false;
    private bool _isPublicRoute = false;
    private static readonly string[] PublicRoutes = ["/login"];

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await CheckAuthAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await CheckAuthAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckAuthAsync()
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath.ToLower();
        _isPublicRoute = PublicRoutes.Contains(currentPath);

        if (_isPublicRoute)
        {
            _isAuthenticated = false;
            _isChecking = false;
            return;
        }

        _isChecking = true;
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();

        if (!_isAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return; // keep _isChecking = true so nothing renders while redirecting
        }

        _isChecking = false;
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}

<style>
    .auth-checking {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }
</style>
